# Database — Neon for hosted, local Postgres for dev/self-hosted
DATABASE_URL=postgres://demolocker:demolocker@localhost:5432/demolocker

# API server
PORT=3001

# S3-compatible storage — Cloudflare R2 for hosted, MinIO for local dev
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=demos
S3_ACCESS_KEY=demolocker
S3_SECRET_KEY=demolocker
S3_REGION=auto

# Limits — leave unset (or 0) for unlimited (self-hosted default)
# Only set these for the hosted version
# MAX_PLAYLISTS=1
# MAX_STORAGE_BYTES=524288000
# MAX_COLLABORATORS=4
